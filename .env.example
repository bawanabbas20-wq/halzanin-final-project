APP_NAME=Halzanin
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://relicsoftware.tech

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=halzanin2@gmail.com
MAIL_PASSWORD="your_gmail_app_password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=halzanin2@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# AI / Third-party APIs
GEMINI_API_KEY=
CALLMEBOT_API_KEY=

VITE_APP_NAME="${APP_NAME}"
